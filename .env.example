# Theo configuration — copy this file to .env and fill in the values you need.
#
# The .env file is gitignored. Only this .env.example ships with the repo.
# Restart the app after changing any of these (sv restart theo, or however
# you run the process).

# ── Required ─────────────────────────────────────────────────────────────────

# Flask session signing key. The default ("dev-secret-key") is fine for
# local development but MUST be replaced with a random string before any
# real use — sessions can otherwise be forged. Generate one with:
#   python3 -c 'import secrets; print(secrets.token_urlsafe(48))'
SECRET_KEY=dev-secret-key


# ── Optional ─────────────────────────────────────────────────────────────────

# Anthropic / Claude API key. Powers the auto-generated J. Peterman-style
# item stories under Settings → Stories. The app runs fine without a key;
# the Stories feature simply stays dormant. Get a key at
# https://console.anthropic.com → API Keys.
ANTHROPIC_API_KEY=

# Port the dev server binds to when you run `python3 app.py` directly.
# Defaults to 5000. The supervised runit service sets its own port.
PORT=5000

# URL printed in the "Generated by Theo" footer of every published GitHub
# Pages index. Defaults to the upstream Theo repo. Fork operators who want
# their own source credited can point this at their fork.
THEO_PROJECT_URL=https://github.com/mrinalinisin/theo
